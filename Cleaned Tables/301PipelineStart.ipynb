from numpy import int64
import pandas as pd

#read file

df = pd.read_csv("work_from_home_burnout_dataset.csv")

print(df.info())
print(df.head(3))


#Goals
  #Remove Null Rows
  #It has come to my attention that the dataset already has no null rows, but I will still briefly preform some opperations to deal with it as though it did, in the spirit of the assignment
df.isnull().sum()

#For each collumn we look for null entries and fill in placeholder data that is easily recognisable in future processing
for col_n in df.columns:
  if col_n == "user_id": #Making null user id's negative for future easier filtering
    df[col_n] = df[col_n].fillna(-1)
  elif (df[col_n].dtype == "float64" or df[col_n].dtype == "int64"):
    df[col_n] = df[col_n].fillna(0)
  else:
    df[col_n] = df[col_n].fillna("Unknown")


  #Identify & Conform Data Types
  #I want to change/confirm the two objects into strings, since I think thall be easier to work with later? If not I can remake this and just remove this bit to keep them as objects
df['day_type'] = df['day_type'].astype('string')
df['burnout_risk'] = df['burnout_risk'].astype('string')


  #Remove Duplicates
df = df.drop_duplicates()


#Save the refreshed table (though not many changes happened dwith this particult dataframe)
df.to_csv("Cleaned.csv", index=False)


  #Make Multiple Tables?
  #make a table with one user id for each user id, and have total hours worked per week as well as total screen time hours per week, maybe also throw total meeting in there too

user_ids = df['user_id'].unique()
total_hours_worked = df.groupby('user_id')['work_hours'].sum()
total_screen_time = df.groupby('user_id')['screen_time_hours'].sum()
total_meetings = df.groupby('user_id')['meetings_count'].sum()
total_breaks = df.groupby('user_id')['breaks_taken'].sum()
total_overtime = df.groupby('user_id')['after_hours_work'].sum()
total_sleep_hours = df.groupby('user_id')['sleep_hours'].sum()
total_burnout_score = df.groupby('user_id')['burnout_score'].sum()

new_df = {'total_hours_worked': total_hours_worked, 'total_screen_time': total_screen_time, 'total_meetings': total_meetings, 'total_breaks': total_breaks, 'total_overtime':total_overtime, 'total_sleep_hours': total_sleep_hours, 'total_burnout_score': total_burnout_score}
new_df = pd.DataFrame(new_df)
print(new_df.head(3))

new_df.to_csv("Summations.csv", index=True)
